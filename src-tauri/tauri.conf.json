{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "船舶装备故障诊断智能问答系统",
  "version": "0.1.0",
  "identifier": "com.mtobdvlb.sigmaflow",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "船舶装备故障诊断智能问答系统",
        "width": 1440,
        "height": 900,
        "minWidth": 1100,
        "minHeight": 720,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
